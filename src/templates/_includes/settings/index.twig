{% import '_includes/forms' as forms %}

<div id="settings">
  <h1>Settings</h1>
  {% namespace 'settings' %}
    {{ forms.selectField({
      first: true,
      name: 'gatewayId',
      label: 'Gateway',
      options: gateways,
      value: settings.gatewayId,
      required: true,
      instructions: 'Select the gateway through which payments will be processed.',
      errors: settings.getErrors('gatewayId')
    }) }}
    {{ forms.selectField({
      name: 'inventoryId',
      label: 'Inventory',
      options: inventories,
      value: settings.inventoryId,
      instructions: 'Select an inventory.',
      errors: settings.getErrors('inventoryId')
    }) }}
    {{ forms.checkboxField({
      label: 'Shipping Address Required',
      instructions: 'Checking this will prompt the user for their shipping address.',
      name: 'shippingAddressRequired',
      checked: settings.shippingAddressRequired,
    }) }}
    {{ forms.checkboxField({
      label: 'Phone Number Required',
      instructions: 'Checking this box will prompt the user for their phone number.',
      name: 'phoneNumberRequired',
      checked: settings.phoneNumberRequired,
    }) }}
    {{ forms.selectField({
      name: 'phoneField',
      instructions: 'Map the phone number to plain text on the order field layout. This will only take effect if you enable \'Phone Number Required\'.',
      label: 'Phone Field',
      options: fields,
      value: settings.phoneField,
      required: false,
    }) }}
    {{ forms.checkboxField({
      label: 'Restrict countries',
      name: 'restrictCountries',
      checked: settings.restrictCountries,
      instructions: 'Checking this will restrict the Stripe \'allowedCountries\' to your country list in Commerce -> Store Settings -> Store -> Country List.'
    }) }}
    {{ forms.textField({
      name: 'successUrl',
      label: 'Success URL',
      value: settings.successUrl,
      required: true,
      instructions: 'The URL that Stripe redirects to after a successful transaction. The \'successUrl\' gets a query parameter called \'number\' that contains the order number.',
      errors: settings.getErrors('successUrl')
    }) }}
    {{ forms.textField({
      name: 'cancelUrl',
      label: 'Cancel URL',
      value: settings.cancelUrl,
      instructions: 'The URL that Stripe will redirect to after the user abandons the checkout process. By default, this is the URL the user came from.'
    }) }}
  {% endnamespace %}
</div>
